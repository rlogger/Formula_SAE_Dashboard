# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ── Admin credentials (used on first startup to create admin user) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_123

# ── JWT secret for signing tokens (generate with: openssl rand -hex 32) ──
JWT_SECRET=generate_a_secure_random_string_here

# ── CORS allowed origins (comma-separated) ──
# This should match the URL you use to access the frontend
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend API URL (used at build time for Next.js) ──
# Set this to the address of your backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Telemetry serial modem (Digi Bee SX) ──
# Serial port device for the Digi Bee SX RX modem
# Data chain: Motec CAN → RS232 → Digi Bee TX → air → Digi Bee RX → this port
# Leave empty to use simulated data only
SERIAL_PORT=
# Baud rate (Digi Bee SX default: 9600)
SERIAL_BAUD=9600
# Data format from the Motec CAN-to-Serial converter: csv, motec_binary, auto
SERIAL_FORMAT=csv
# Telemetry source preference: auto, serial, udp_broadcast, simulated
# auto = prefer serial → UDP broadcast → simulated
TELEMETRY_SOURCE=auto

# ── WiFi broadcast telemetry (UDP) ──
# Passive UDP listener for broadcast-only mode: the car broadcasts telemetry
# packets over WiFi and the dashboard just listens (no handshake).
# Tip: set format to "raw" and use Wireshark + Packet Capture tab to inspect
# traffic before configuring parsing.
UDP_PORT=50000
UDP_BIND_ADDRESS=0.0.0.0
# Packet format: csv, json, raw, auto
UDP_PACKET_FORMAT=auto
